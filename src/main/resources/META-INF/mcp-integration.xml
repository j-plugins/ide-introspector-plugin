<idea-plugin>

    <extensions defaultExtensionNs="com.intellij">
        <mcpServer.mcpToolset implementation="com.github.xepozz.ide.introspector.tools.UiInspectorToolset"/>
        <mcpServer.mcpToolset implementation="com.github.xepozz.ide.introspector.tools.ScreenshotToolset"/>
        <mcpServer.mcpToolset implementation="com.github.xepozz.ide.introspector.tools.ArchitectureToolset"/>
        <mcpServer.mcpToolset implementation="com.github.xepozz.ide.introspector.tools.ServicesToolset"/>
        <mcpServer.mcpToolset implementation="com.github.xepozz.ide.introspector.tools.EventsToolset"/>
        <mcpServer.mcpToolset implementation="com.github.xepozz.ide.introspector.tools.PsiToolset"/>
        <mcpServer.mcpToolset implementation="com.github.xepozz.ide.introspector.tools.IdeStateToolset"/>
        <mcpServer.mcpToolset implementation="com.github.xepozz.ide.introspector.tools.EditorToolset"/>
        <mcpServer.mcpToolset implementation="com.github.xepozz.ide.introspector.tools.SkillToolset"/>
        <mcpServer.mcpToolset implementation="com.github.xepozz.ide.introspector.tools.ContextToolset"/>
        <!-- ExecToolset was previously gated by `kotlin-exec.xml` depending on the Kotlin
             plugin. Kotlin scripting here uses kotlin-scripting-jsr223 via standard
             javax.script — bundled in our plugin classloader, no Kotlin IDE plugin needed.
             K2-mode plugin gating was therefore both unnecessary and silently disabling
             exec on modern IDEs. Registered unconditionally now. -->
        <mcpServer.mcpToolset implementation="com.github.xepozz.ide.introspector.tools.ExecToolset"/>
    </extensions>
</idea-plugin>
